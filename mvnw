basedir="$(dirname "$0")"
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR="$basedir"
fi

if [ ! -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" ]; then
  echo "Maven wrapper jar not found: $MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
  exit 1
fi

exec java -cp "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" org.apache.maven.wrapper.MavenWrapperMain "$@"
